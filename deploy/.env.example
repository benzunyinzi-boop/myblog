# ============================================================
# myblog deploy environment example
# 复制为 deploy/.env 后按需修改
# ============================================================

COMPOSE_PROJECT_NAME=myblog
TZ=Asia/Shanghai

# 端口映射
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# MySQL
MYSQL_DATABASE=myblog
MYSQL_USER=myblog
MYSQL_PASSWORD=myblog123
MYSQL_ROOT_PASSWORD=root123456

# Redis
REDIS_PASSWORD=

# Backend runtime
MYBLOG_SERVER_HOST=0.0.0.0
MYBLOG_SERVER_PORT=8080
MYBLOG_SERVER_MODE=release
MYBLOG_LOG_LEVEL=info
MYBLOG_LOG_FORMAT=json
MYBLOG_LOG_OUTPUT=stdout
MYBLOG_JWT_SECRET=change-me-in-prod
MYBLOG_JWT_ACCESS_TTL=2h
MYBLOG_JWT_REFRESH_TTL=168h
MYBLOG_JWT_ISSUER=myblog

# 前端生产构建会在 web/.env.production 中使用 /api/v1
