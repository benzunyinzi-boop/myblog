# ==== myblog 环境变量示例 ====
# 复制为 .env 后按需修改(.env 已在 .gitignore)

# ---- Server ----
MYBLOG_SERVER_HOST=0.0.0.0
MYBLOG_SERVER_PORT=8080
MYBLOG_SERVER_MODE=debug   # debug / release / test

# ---- Log ----
MYBLOG_LOG_LEVEL=info       # debug / info / warn / error
MYBLOG_LOG_FORMAT=json      # json / console
MYBLOG_LOG_OUTPUT=stdout    # stdout / file

# ---- JWT(M2 启用) ----
MYBLOG_JWT_SECRET=change-me-in-prod
MYBLOG_JWT_ACCESS_TTL=2h
MYBLOG_JWT_REFRESH_TTL=168h
MYBLOG_JWT_ISSUER=myblog

# ---- MySQL(M2 启用) ----
MYBLOG_MYSQL_DSN=myblog:password@tcp(127.0.0.1:3306)/myblog?charset=utf8mb4&parseTime=true&loc=Local
MYBLOG_MYSQL_MAX_OPEN_CONNS=50
MYBLOG_MYSQL_MAX_IDLE_CONNS=10
MYBLOG_MYSQL_CONN_MAX_LIFETIME=1h

# ---- Redis(M2 启用) ----
MYBLOG_REDIS_ADDR=127.0.0.1:6379
MYBLOG_REDIS_PASSWORD=
MYBLOG_REDIS_DB=0
